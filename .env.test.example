# Credenciais para testes E2E (Playwright) e RLS.
# Copie para .env.test (gitignored) e preencha. NUNCA commite o .env.test.
#
# Crie 2 usuários QA dedicados no Supabase Auth antes de rodar:
#   - qa-diretor@consej.com   → perfil interno com role 'diretor'
#   - qa-consultor@consej.com → perfil interno com role 'consultor'
# O consultor deve ter alguns leads/clientes atribuídos para os testes de RLS.

QA_DIRETOR_EMAIL=qa-diretor@consej.com
QA_DIRETOR_PASSWORD=
QA_CONSULTOR_EMAIL=qa-consultor@consej.com
QA_CONSULTOR_PASSWORD=

# Usados pelos testes de RLS (tests/rls/) — mesmos valores do .env do app
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Opcional: sobrescrever a URL base do app em teste
# E2E_BASE_URL=http://localhost:5173
